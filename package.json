{
  "name": "dossier",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "start": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "deploy": "pnpm --filter api deploy",
    "add-device": "pnpm --filter api add-device",
    "explorer": "pnpm --filter api db:studio",
    "db:clean": "pnpm --filter api db:clean",
    "register-device:remote": "pnpm --filter api exec tsx ../../scripts/register-device-remote.ts",
    "format": "pnpm -r run format"
  }
}