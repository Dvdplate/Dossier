{
  "name": "dossier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "start": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "deploy": "pnpm --filter api deploy",
    "add-device": "pnpm --filter api add-device",
    "format": "pnpm -r run format"
  }
}