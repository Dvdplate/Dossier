{
  "name": "dossier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "backend:dev": "pnpm --filter api dev",
    "backend:build": "pnpm --filter api build",
    "backend:typecheck": "pnpm --filter api typecheck",
    "backend:deploy": "pnpm --filter api deploy",
    "backend:add-device": "pnpm --filter api add-device",
    "frontend:dev": "pnpm --filter web dev",
    "frontend:build": "pnpm --filter web build",
    "frontend:typecheck": "pnpm --filter web typecheck",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "format": "pnpm -r run format"
  }
}