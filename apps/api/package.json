  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250530.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  }
}
